const vect_a : {ax: Int, ay: Int} = {ax = 3, ay = 4}
const vect_b : {bx: Int, by: Int} = {bx = 7, by = 2}

fun dot_prod_2d (a, b) : ({ax: Int, ay: Int}, {bx: Int, by: Int}) -> Int =
    a.ax*b.bx + a.ay*b.by

fun main (_) : Unit -> Unit =
    print(dot_prod_2d(vect_a, vect_b))